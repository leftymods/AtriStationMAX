/dts-v1/;

/ {
	compatible = "amlogic, sm1";
	interrupt-parent = < 0x01 >;
	#address-cells = < 0x02 >;
	#size-cells = < 0x02 >;
	model = "AtriStation ATR-01";
	vendor = "leftymods";
	product-name = "AtriStation";
	product-model = "ATR";
	product-version = "01";
	amlogic-dt-id = "sm1_s905x3_atristation_atr_01";

	bifrost {
		compatible = "arm,malit60x\0arm,malit6xx\0arm,mali-midgard";
		#cooling-cells = < 0x02 >;
		reg = < 0x00 0xffe40000 0x00 0x4000 0x00 0xffd01000 0x00 0x1000 0x00 0xff800000 0x00 0x1000 0x00 0xff63c000 0x00 0x1000 0x00 0xffd01000 0x00 0x1000 >;
		interrupt-parent = < 0x01 >;
		interrupts = < 0x00 0xa0 0x04 0x00 0xa1 0x04 0x00 0xa2 0x04 >;
		interrupt-names = "GPU\0MMU\0JOB";
		num_of_pp = < 0x02 >;
		sc_mpp = < 0x01 >;
		clocks = < 0x02 0x83 0x02 0x07 >;
		clock-names = "gpu_mux\0gp0_pll";
		tbl = < 0x03 0x04 0x05 0x06 0x07 0x07 >;
		phandle = < 0x9c >;

		clk125_cfg {
			clk_freq = < 0x7735940 >;
			clk_parent = "fclk_div4";
			clkp_freq = < 0x1dcd6500 >;
			clk_reg = < 0xa03 >;
			voltage = < 0x47e >;
			keep_count = < 0x05 >;
			threshold = < 0x1e 0x78 >;
			phandle = < 0x9d >;
		};

		dvfs250_cfg {
			clk_freq = < 0xee6b280 >;
			clk_parent = "fclk_div4";
			clkp_freq = < 0x1dcd6500 >;
			clk_reg = < 0xa01 >;
			voltage = < 0x47e >;
			keep_count = < 0x05 >;
			threshold = < 0x50 0xaa >;
			phandle = < 0x9e >;
		};

		dvfs285_cfg {
			clk_freq = < 0x1107a76d >;
			clk_parent = "fclk_div7";
			clkp_freq = < 0x1107a76d >;
			clk_reg = < 0xe00 >;
			voltage = < 0x47e >;
			keep_count = < 0x05 >;
			threshold = < 0x64 0xbe >;
			phandle = < 0x03 >;
		};

		dvfs400_cfg {
			clk_freq = < 0x17d78400 >;
			clk_parent = "fclk_div5";
			clkp_freq = < 0x17d78400 >;
			clk_reg = < 0xc00 >;
			voltage = < 0x47e >;
			keep_count = < 0x05 >;
			threshold = < 0x98 0xcf >;
			phandle = < 0x04 >;
		};

		dvfs500_cfg {
			clk_freq = < 0x1dcd6500 >;
			clk_parent = "fclk_div4";
			clkp_freq = < 0x1dcd6500 >;
			clk_reg = < 0xa00 >;
			voltage = < 0x47e >;
			keep_count = < 0x05 >;
			threshold = < 0xb4 0xdc >;
			phandle = < 0x05 >;
		};

		dvfs666_cfg {
			clk_freq = < 0x27bc86aa >;
			clk_parent = "fclk_div3";
			clkp_freq = < 0x27bc86aa >;
			clk_reg = < 0x800 >;
			voltage = < 0x47e >;
			keep_count = < 0x05 >;
			threshold = < 0xd2 0xec >;
			phandle = < 0x06 >;
		};

		dvfs800_cfg {
			clk_freq = < 0x2faf0800 >;
			clk_parent = "fclk_div2p5";
			clkp_freq = < 0x2faf0800 >;
			clk_reg = < 0x600 >;
			voltage = < 0x47e >;
			keep_count = < 0x05 >;
			threshold = < 0xe6 0xff >;
			phandle = < 0x9f >;
		};

		dvfs850_cfg {
			clk_freq = < 0x326cef80 >;
			clk_parent = "gp0_pll";
			clkp_freq = < 0x326cef80 >;
			clk_reg = < 0x200 >;
			voltage = < 0x47e >;
			keep_count = < 0x05 >;
			threshold = < 0xe6 0xff >;
			phandle = < 0x07 >;
		};
	};

	cpus {
		#address-cells = < 0x02 >;
		#size-cells = < 0x00 >;
		phandle = < 0xa0 >;

		cpu-map {

			cluster0 {
				phandle = < 0xa1 >;

				core0 {
					cpu = < 0x08 >;
				};

				core1 {
					cpu = < 0x09 >;
				};

				core2 {
					cpu = < 0x0a >;
				};

				core3 {
					cpu = < 0x0b >;
				};
			};
		};

		cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a53\0arm,armv8";
			reg = < 0x00 0x00 >;
			enable-method = "psci";
			cpu-idle-states = < 0x0c >;
			clocks = < 0x02 0x17 0x02 0x16 0x02 0x00 >;
			clock-names = "core_clk\0low_freq_clk_parent\0high_freq_clk_parent";
			operating-points-v2 = < 0x0d >;
			cpu-supply = < 0x0e >;
			voltage-tolerance = < 0x00 >;
			clock-latency = < 0xc350 >;
			phandle = < 0x08 >;
		};

		cpu@1 {
			device_type = "cpu";
			compatible = "arm,cortex-a53\0arm,armv8";
			reg = < 0x00 0x01 >;
			enable-method = "psci";
			cpu-idle-states = < 0x0c >;
			clocks = < 0x02 0x17 0x02 0x16 0x02 0x00 >;
			clock-names = "core_clk\0low_freq_clk_parent\0high_freq_clk_parent";
			operating-points-v2 = < 0x0d >;
			cpu-supply = < 0x0e >;
			voltage-tolerance = < 0x00 >;
			clock-latency = < 0xc350 >;
			phandle = < 0x09 >;
		};

		cpu@2 {
			device_type = "cpu";
			compatible = "arm,cortex-a53\0arm,armv8";
			reg = < 0x00 0x02 >;
			enable-method = "psci";
			cpu-idle-states = < 0x0c >;
			clocks = < 0x02 0x17 0x02 0x16 0x02 0x00 >;
			clock-names = "core_clk\0low_freq_clk_parent\0high_freq_clk_parent";
			operating-points-v2 = < 0x0d >;
			cpu-supply = < 0x0e >;
			voltage-tolerance = < 0x00 >;
			clock-latency = < 0xc350 >;
			phandle = < 0x0a >;
		};

		cpu@3 {
			device_type = "cpu";
			compatible = "arm,cortex-a53\0arm,armv8";
			reg = < 0x00 0x03 >;
			enable-method = "psci";
			cpu-idle-states = < 0x0c >;
			clocks = < 0x02 0x17 0x02 0x16 0x02 0x00 >;
			clock-names = "core_clk\0low_freq_clk_parent\0high_freq_clk_parent";
			operating-points-v2 = < 0x0d >;
			cpu-supply = < 0x0e >;
			voltage-tolerance = < 0x00 >;
			clock-latency = < 0xc350 >;
			phandle = < 0x0b >;
		};

		idle-states {
			entry-method = "arm,psci-0.2";

			cpu-sleep-0 {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = < 0x10000 >;
				local-timer-stop;
				entry-latency-us = < 0x1388 >;
				exit-latency-us = < 0x1388 >;
				min-residency-us = < 0x3a98 >;
				phandle = < 0x0c >;
			};
		};
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts = < 0x01 0x0d 0xff08 0x01 0x0e 0xff08 0x01 0x0b 0xff08 0x01 0x0a 0xff08 >;
	};

	timer_bc {
		compatible = "arm, meson-bc-timer";
		reg = < 0x00 0xffd0f190 0x00 0x04 0x00 0xffd0f194 0x00 0x04 >;
		timer_name = "Meson TimerF";
		clockevent-rating = < 0x12c >;
		clockevent-shift = < 0x14 >;
		clockevent-features = < 0x23 >;
		interrupts = < 0x00 0x3c 0x01 >;
		bit_enable = < 0x10 >;
		bit_mode = < 0x0c >;
		bit_resolution = < 0x00 >;
	};

	arm_pmu {
		compatible = "arm,armv8-pmuv3";
		interrupts = < 0x00 0x89 0x04 >;
		reg = < 0x00 0xff634680 0x00 0x04 >;
		cpumasks = < 0x0f >;
		relax-timer-ns = < 0x989680 >;
		max-wait-cnt = < 0x2710 >;
	};

	interrupt-controller@2c001000 {
		compatible = "arm,cortex-a15-gic\0arm,cortex-a9-gic";
		#interrupt-cells = < 0x03 >;
		#address-cells = < 0x00 >;
		interrupt-controller;
		reg = < 0x00 0xffc01000 0x00 0x1000 0x00 0xffc02000 0x00 0x100 >;
		interrupts = < 0x01 0x09 0xf04 >;
		phandle = < 0x01 >;
	};

	psci {
		compatible = "arm,psci-0.2";
		method = "smc";
	};

	pm {
		compatible = "amlogic, pm";
		status = "okay";
		device_name = "aml_pm";
		reg = < 0x00 0xff8000a8 0x00 0x04 0x00 0xff80023c 0x00 0x04 >;
		phandle = < 0xa2 >;
	};

	secmon {
		compatible = "amlogic, secmon";
		memory-region = < 0x0f >;
		in_base_func = < 0x82000020 >;
		out_base_func = < 0x82000021 >;
		reserve_mem_size = < 0x300000 >;
	};

	securitykey {
		compatible = "aml, securitykey";
		storage_query = < 0x82000060 >;
		storage_read = < 0x82000061 >;
		storage_write = < 0x82000062 >;
		storage_tell = < 0x82000063 >;
		storage_verify = < 0x82000064 >;
		storage_status = < 0x82000065 >;
		storage_list = < 0x82000067 >;
		storage_remove = < 0x82000068 >;
		storage_in_func = < 0x82000023 >;
		storage_out_func = < 0x82000024 >;
		storage_block_func = < 0x82000025 >;
		storage_size_func = < 0x82000027 >;
		storage_set_enctype = < 0x8200006a >;
		storage_get_enctype = < 0x8200006b >;
		storage_version = < 0x8200006c >;
	};

	mhu@c883c400 {
		compatible = "amlogic, meson_mhu";
		reg = < 0x00 0xff63c400 0x00 0x4c 0x00 0xfffe7000 0x00 0x800 >;
		interrupts = < 0x00 0xd1 0x01 0x00 0xd2 0x01 >;
		#mbox-cells = < 0x01 >;
		mbox-names = "cpu_to_scp_low\0cpu_to_scp_high";
		mboxes = < 0x10 0x00 0x10 0x01 >;
		phandle = < 0x10 >;
	};

	cpu_iomap {
		compatible = "amlogic, iomap";
		#address-cells = < 0x02 >;
		#size-cells = < 0x02 >;
		ranges;

		io_cbus_base {
			reg = < 0x00 0xffd00000 0x00 0x26000 >;
		};

		io_apb_base {
			reg = < 0x00 0xffe01000 0x00 0x7f000 >;
		};

		io_aobus_base {
			reg = < 0x00 0xff800000 0x00 0xb000 >;
		};

		io_vapb_base {
			reg = < 0x00 0xff900000 0x00 0x50000 >;
		};

		io_hiu_base {
			reg = < 0x00 0xff63c000 0x00 0x2000 >;
		};
	};

	xtal-clk {
		compatible = "fixed-clock";
		clock-frequency = < 0x16e3600 >;
		clock-output-names = "xtal";
		#clock-cells = < 0x00 >;
		phandle = < 0x14 >;
	};

	rtc {
		compatible = "amlogic, aml_vrtc";
		alarm_reg_addr = < 0xff8000a8 >;
		timer_e_addr = < 0xffd0f188 >;
		init_date = "2015/01/01";
		status = "okay";
	};

	cpu_info {
		compatible = "amlogic, cpuinfo";
		status = "okay";
		cpuinfo_cmd = < 0x82000044 >;
	};

	aml_reboot {
		compatible = "aml, reboot";
		sys_reset = < 0x84000009 >;
		sys_poweroff = < 0x84000008 >;
	};

	vpu {
		compatible = "amlogic, vpu-sm1";
		dev_name = "vpu";
		status = "okay";
		clocks = < 0x02 0x95 0x02 0x4c 0x02 0x87 0x02 0x8b 0x02 0x8c >;
		clock-names = "vapb_clk\0vpu_intr_gate\0vpu_clk0\0vpu_clk1\0vpu_clk";
		clk_level = < 0x07 >;
	};

	ethernet@ff3f0000 {
		compatible = "amlogic, sm1-eth-dwmac\0snps,dwmac";
		reg = < 0x00 0xff3f0000 0x00 0x10000 0x00 0xff634540 0x00 0x08 0x00 0xff64c000 0x00 0xa0 >;
		reg-names = "eth_base\0eth_cfg\0eth_pll";
		interrupts = < 0x00 0x08 0x01 >;
		interrupt-names = "macirq";
		status = "okay";
		clocks = < 0x02 0x38 >;
		clock-names = "ethclk81";
		pll_val = < 0x9c0040a 0x927e0000 0xac5f49e5 >;
		analog_val = < 0x20200000 0xc000 0x23 >;
		pinctrl-names = "external_eth_pins";
		pinctrl-0 = < 0x11 >;
		mc_val = < 0x1621 >;
		internal_phy = < 0x00 >;
		phandle = < 0xa3 >;
	};

	pinctrl@ff800014 {
		compatible = "amlogic,meson-sm1-aobus-pinctrl";
		#address-cells = < 0x02 >;
		#size-cells = < 0x02 >;
		ranges;
		phandle = < 0xa4 >;

		ao-bank@ff800014 {
			reg = < 0x00 0xff800014 0x00 0x08 0x00 0xff800024 0x00 0x14 0x00 0xff80001c 0x00 0x08 >;
			reg-names = "mux\0gpio\0drive-strength";
			gpio-controller;
			#gpio-cells = < 0x02 >;
			phandle = < 0x15 >;
		};

		sd_to_ao_uart_clr_pins {
			phandle = < 0x44 >;

			mux {
				groups = "GPIOAO_0\0GPIOAO_1";
				function = "gpio_aobus";
			};
		};

		sd_to_ao_uart_pins {
			phandle = < 0x46 >;

			mux {
				groups = "uart_ao_tx_a\0uart_ao_rx_a";
				function = "uart_ao_a";
				bias-pull-up;
				input-enable;
			};
		};

		ao_uart {
			phandle = < 0xa5 >;

			mux {
				groups = "uart_ao_tx_a\0uart_ao_rx_a";
				function = "uart_ao_a";
			};
		};

		ao_b_uart {
			phandle = < 0x1e >;

			mux {
				groups = "uart_ao_tx_b_2\0uart_ao_rx_b_3";
				function = "uart_ao_b";
			};
		};

		ao_i2c_pins1 {
			phandle = < 0xa6 >;

			mux {
				groups = "i2c_ao_sck\0i2c_ao_sda";
				function = "i2c_ao";
				drive-strength = < 0x02 >;
			};
		};

		ao_i2c_pins2 {
			phandle = < 0xa7 >;

			mux {
				groups = "i2c_ao_sck_e\0i2c_ao_sda_e";
				function = "i2c_ao";
				drive-strength = < 0x02 >;
			};
		};

		ao_i2c_slave_pins {
			phandle = < 0x1d >;

			mux {
				groups = "i2c_ao_slave_sck\0i2c_ao_slave_sda";
				function = "i2c_ao_slave";
			};
		};

		pwm_ao_a {
			phandle = < 0xa8 >;

			mux {
				groups = "pwm_ao_a";
				function = "pwm_ao_a";
			};
		};

		pwm_ao_a_hiz {
			phandle = < 0xa9 >;

			mux {
				groups = "pwm_ao_a_hiz";
				function = "pwm_ao_a";
			};
		};

		pwm_ao_b {
			phandle = < 0xaa >;

			mux {
				groups = "pwm_ao_b";
				function = "pwm_ao_b";
			};
		};

		pwm_ao_c_pins1 {
			phandle = < 0xab >;

			mux {
				groups = "pwm_ao_c_4";
				function = "pwm_ao_c";
			};
		};

		pwm_ao_c_pins2 {
			phandle = < 0xac >;

			mux {
				groups = "pwm_ao_c_6";
				function = "pwm_ao_c";
			};
		};

		pwm_ao_c_hiz {
			phandle = < 0xad >;

			mux {
				groups = "pwm_ao_c_hiz_4";
				function = "pwm_ao_c";
			};
		};

		pwm_ao_d_pins1 {
			phandle = < 0xae >;

			mux {
				groups = "pwm_ao_d_5";
				function = "pwm_ao_d";
			};
		};

		pwm_ao_d_pins2 {
			phandle = < 0xaf >;

			mux {
				groups = "pwm_ao_d_10";
				function = "pwm_ao_d";
			};
		};

		pwm_ao_d_pins3 {
			phandle = < 0x9a >;

			mux {
				groups = "pwm_ao_d_e";
				function = "pwm_ao_d";
			};
		};

		ao_ceca {
			phandle = < 0xb0 >;

			mux {
				groups = "cec_ao_a";
				function = "cec_ao";
			};
		};

		ao_cecb {
			phandle = < 0xb1 >;

			mux {
				groups = "cec_ao_b";
				function = "cec_ao";
			};
		};

		remote_pin {
			phandle = < 0x2b >;

			mux {
				groups = "remote_input_ao";
				function = "remote_input_ao";
			};
		};

		irblaster_pin {
			phandle = < 0x3d >;

			mux {
				groups = "remote_out_ao";
				function = "remote_out_ao";
			};
		};

		tdmb_mclk {
			phandle = < 0x23 >;

			mux {
				groups = "mclk0_ao";
				function = "mclk0_ao";
				drive-strength = < 0x02 >;
			};
		};

		gpio_ampl_pwr {
			phandle = < 0xb2 >;

			mux {
				pins = "GPIOAO_10";
				function = "gpio_aobus";
				output-low;
			};
		};

		tdmin_b {
			phandle = < 0x25 >;

			mux {
				groups = "tdmb_din0_ao";
				function = "tdmb_in_ao";
				drive-strength = < 0x02 >;
			};
		};

		tdmout_b {
			phandle = < 0x24 >;

			mux {
				groups = "tdmb_fs_ao\0tdmb_sclk_ao\0tdmb_dout2_ao";
				function = "tdmb_out_ao";
				drive-strength = < 0x02 >;
			};
		};
	};

	pinctrl@ff634480 {
		compatible = "amlogic,meson-sm1-periphs-pinctrl";
		#address-cells = < 0x02 >;
		#size-cells = < 0x02 >;
		ranges;
		phandle = < 0xb3 >;

		banks@ff6346c0 {
			reg = < 0x00 0xff6346c0 0x00 0x40 0x00 0xff6344e8 0x00 0x18 0x00 0xff634520 0x00 0x18 0x00 0xff634440 0x00 0x4c 0x00 0xff634740 0x00 0x1c >;
			reg-names = "mux\0pull\0pull-enable\0gpio\0drive-strength";
			gpio-controller;
			#gpio-cells = < 0x02 >;
			phandle = < 0x16 >;
		};

		emmc_clk_cmd_pins {
			phandle = < 0x3e >;

			mux {
				groups = "emmc_clk\0emmc_cmd";
				function = "emmc";
				input-enable;
				bias-pull-up;
			};
		};

		emmc_conf_pull_up {
			phandle = < 0x3f >;

			mux {
				groups = "emmc_nand_d7\0emmc_nand_d6\0emmc_nand_d5\0emmc_nand_d4\0emmc_nand_d3\0emmc_nand_d2\0emmc_nand_d1\0emmc_nand_d0\0emmc_clk\0emmc_cmd";
				function = "emmc";
				input-enable;
				bias-pull-up;
			};
		};

		emmc_conf_pull_done {
			phandle = < 0x40 >;

			mux {
				groups = "emmc_nand_ds";
				function = "emmc";
				input-enable;
				bias-pull-down;
			};
		};

		sd_clk_cmd_pins {
			phandle = < 0x42 >;

			mux {
				groups = "sdcard_cmd_c";
				function = "sdcard";
				input-enable;
				bias-pull-up;
				drive-strength = < 0x03 >;
			};

			mux1 {
				groups = "sdcard_clk_c";
				function = "sdcard";
				bias-pull-up;
				output-high;
				drive-strength = < 0x03 >;
			};
		};

		sd_all_pins {
			phandle = < 0x41 >;

			mux {
				groups = "sdcard_d0_c\0sdcard_d1_c\0sdcard_d2_c\0sdcard_d3_c\0sdcard_cmd_c";
				function = "sdcard";
				input-enable;
				bias-pull-up;
				drive-strength = < 0x03 >;
			};

			mux1 {
				groups = "sdcard_clk_c";
				function = "sdcard";
				bias-pull-up;
				output-high;
				drive-strength = < 0x03 >;
			};
		};

		sd_1bit_pins {
			phandle = < 0x43 >;

			mux {
				groups = "sdcard_d0_c\0sdcard_cmd_c";
